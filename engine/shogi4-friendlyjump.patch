+// Shogi4 friendly-jump: for each step direction in which an adjacent square holds a
+// friendly piece (a "screen"), the piece may leap to the square two steps out in that
+// same direction. Given the piece's base step bitboard, the screens are its step
+// squares that are occupied by a friendly piece, and each landing square is the
+// reflection of the origin through its screen, i.e. 2*screen - origin. This is only
+// sound for single-step leapers (all Shogi4 pieces), the only context it runs in.
+// Own-occupied / off-board landings are masked off by the callers (board_bb / target).
+inline Bitboard Position::friendly_jumps(Color c, Square s, Bitboard steps) const {
+  Bitboard jumps = 0;
+  Bitboard screens = steps & pieces(c);
+  while (screens)
+  {
+      Square m = pop_lsb(screens);
+      int f = 2 * file_of(m) - file_of(s);
+      int r = 2 * rank_of(m) - rank_of(s);
+      if (f >= FILE_A && f <= max_file() && r >= RANK_1 && r <= max_rank())
+          jumps |= square_bb(make_square(File(f), Rank(r)));
+  }
+  return jumps;
+}
+
 inline Bitboard Position::attacks_from(Color c, PieceType pt, Square s) const {
   if (var->fastAttacks || var->fastAttacks2)
       return attacks_bb(c, pt, s, byTypeBB[ALL_PIECES]) & board_bb();
@@ -1299,6 +1321,8 @@ inline Bitboard Position::attacks_from(Color c, PieceType pt, Square s) const {
               & ~pieces(pt)
               & diagonal_lines();
   }
+  if (var->friendlyJump)
+      b |= friendly_jumps(c, s, b);
   return b & board_bb(c, pt);
 }
 
@@ -1332,6 +1356,8 @@ inline Bitboard Position::moves_from(Color c, PieceType pt, Square s) const {
               & ~pieces(pt)
               & diagonal_lines();
   }
+  if (var->friendlyJump)
+      b |= friendly_jumps(c, s, b);
   return b & board_bb(c, pt);
 }
 
