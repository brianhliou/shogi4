{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "sh tools/build-explorer-public.sh",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://brianhliou.com https://www.brianhliou.com http://localhost:4000"
        }
      ]
    }
  ]
}
